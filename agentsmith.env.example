# agentsmith secrets — copy to agentsmith.env (gitignored) and fill in real values.
# These are referenced in config.yaml via ${VAR} interpolation.
# agentsmith will fail to start if any referenced variable is unset.

# Dodo Payments MCP backend
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_key_here

# Slack MCP backend
SLACK_TOKEN=xoxb-your-slack-bot-token-here
