package ui

// sharedHead renders the common <head> element for every admin page.
// All shared and page-specific CSS lives here so there is a single source
// of truth for the design system.
templ sharedHead(title string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1"/>
		<title>{ title }</title>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css"/>
		<link rel="icon" href='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 16 16%22><text y=%2213%22 font-size=%2213%22>⚙️</text></svg>'/>
		<script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js"></script>
		<style>
			/* ── design tokens ────────────────────────────── */
			:root {
				--as-font-mono: ui-monospace, "JetBrains Mono", "IBM Plex Mono", "SF Mono", Menlo, Consolas, monospace;
				--as-ok:    #6fcf97;
				--as-warn:  #f2c94c;
				--as-bad:   #eb5757;
				--as-info:  #5dade2;
				--as-muted: rgba(255,255,255,0.55);
				/* latency buckets, consumed by Stages 3+4 */
				--as-lat-fast: #6fcf97;
				--as-lat-ok:   #f2c94c;
				--as-lat-slow: #f2994a;
				--as-lat-bad:  #eb5757;
			}
			code, pre, .mono { font-family: var(--as-font-mono); }
			.num { text-align: right; font-variant-numeric: tabular-nums; }
			.refresh-dot {
				display: inline-block;
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: var(--as-info);
				animation: as-pulse 2s ease-in-out infinite;
			}
			@keyframes as-pulse { 0%,100% { opacity: 0.35; } 50% { opacity: 1; } }
			.trusted-network-banner {
				background: var(--as-warn);
				color: #000;
				padding: 0.4rem 1rem;
				text-align: center;
				font-size: 0.85em;
				font-weight: 500;
			}
			.detail-page-header {
				position: sticky;
				top: 0;
				z-index: 50;
				background: var(--pico-background-color);
			}
			/* full-width main; trim padding at narrow widths so tables breathe */
			.as-main { padding-left: 2rem; padding-right: 2rem; max-width: 1600px; margin-left: auto; margin-right: auto; }
			@media (max-width: 900px) {
				.as-main { padding-left: 0.75rem; padding-right: 0.75rem; }
				.as-main article { padding-left: 0.75rem; padding-right: 0.75rem; }
			}
			/* always-visible horizontal scrollbar inside a table figure, so users
			   know they can scroll on macOS (which auto-hides overlay scrollbars).
			   -webkit-appearance:none is what forces a non-overlay scrollbar in Safari/Chrome. */
			.table-scroll { overflow-x: auto; scrollbar-width: thin; }
			.table-scroll::-webkit-scrollbar { -webkit-appearance: none; height: 8px; }
			.table-scroll::-webkit-scrollbar-thumb {
				background: rgba(255,255,255,0.25);
				border-radius: 4px;
			}
			.table-scroll::-webkit-scrollbar-track {
				background: rgba(255,255,255,0.05);
			}
			/* drop low-signal columns + tighten cell padding on narrow viewports so the table fits without scrolling */
			@media (max-width: 900px) {
				.backend-url { display: none; }
				.col-last-connected { display: none; }
				.as-main article table th,
				.as-main article table td {
					padding: 0.5rem 0.4rem;
					font-size: 0.9em;
				}
			}

			/* ── state badges ─────────────────────────────── */
			.state-badge {
				display: inline-block;
				padding: 0.15em 0.6em;
				border-radius: 999px;
				font-size: 0.75em;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.state-connected  { background: #1a4731; color: #6fcf97; }
			.state-connecting { background: #4a3000; color: #f2c94c; }
			.state-error      { background: #4a1010; color: #eb5757; }

			/* ── annotation badges (detail page) ─────────── */
			.badge-readonly    { background: #1a4731; color: #6fcf97; }
			.badge-idempotent  { background: #1a2f50; color: #5dade2; }
			.badge-destructive { background: #4a1010; color: #eb5757; }

			/* ── utility ─────────────────────────────────── */
			.dim         { opacity: 0.55; font-size: 0.85em; }
			.panel-header { display: flex; justify-content: space-between; align-items: center; }

			/* ── detail page ─────────────────────────────── */
			.meta-chips { display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap; }
			.tool-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.badge-row   { display: flex; gap: 0.4rem; flex-wrap: wrap; }
			table.params { font-size: 0.85em; }
			table.params td, table.params th { white-space: nowrap; }
			table.params td:last-child        { white-space: normal; }

			/* ── schema tree (Stage 2) ───────────────────── */
			.schema-section { margin-top: 1rem; }
			.schema-section-header {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.5rem;
			}
			.schema-row {
				padding: 0.4rem 0;
				border-bottom: 1px solid rgba(255,255,255,0.06);
			}
			.schema-row:last-child { border-bottom: none; }
			.schema-row-main {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				flex-wrap: wrap;
			}
			.schema-row-desc {
				color: var(--as-muted);
				font-size: 0.85em;
				margin: 0.2rem 0 0;
			}
			.schema-children { margin-top: 0.3rem; }
			.schema-details > summary {
				color: var(--as-muted);
				font-size: 0.78em;
				cursor: pointer;
				user-select: none;
				margin-top: 0.25rem;
			}

			.raw-toggle { margin-left: auto; }
			.raw-toggle > summary {
				cursor: pointer;
				user-select: none;
				font-size: 0.75em;
				color: var(--as-muted);
				list-style: none;
			}
			.raw-toggle > summary::before { content: "▸ "; }
			.raw-toggle[open] > summary::before { content: "▾ "; }
			.raw-toggle > pre {
				margin-top: 0.4rem;
				font-size: 0.75em;
				padding: 0.6rem;
				overflow-x: auto;
				border-radius: 4px;
			}

			.type-pill {
				display: inline-block;
				padding: 0.05em 0.5em;
				border-radius: 4px;
				font-size: 0.72em;
				font-weight: 600;
				font-family: var(--as-font-mono);
				letter-spacing: 0.02em;
			}
			.type-string                  { background: #1a2f50; color: var(--as-info); }
			.type-number, .type-integer   { background: #4a3000; color: var(--as-warn); }
			.type-boolean                 { background: #1a4731; color: var(--as-ok); }
			.type-object, .type-array     { background: #2a2a50; color: #a29bfe; }
			.type-null, .type-any         { background: rgba(255,255,255,0.08); color: var(--as-muted); }

			.required-dot {
				display: inline-block;
				width: 7px; height: 7px;
				border-radius: 50%;
				background: var(--as-bad);
				flex-shrink: 0;
			}
			.required-dot.optional {
				background: transparent;
				border: 1px solid rgba(255,255,255,0.3);
			}

			.chip {
				display: inline-block;
				padding: 0.05em 0.45em;
				border-radius: 4px;
				background: rgba(255,255,255,0.08);
				font-family: var(--as-font-mono);
				font-size: 0.72em;
				color: rgba(255,255,255,0.75);
			}
			.chip-enum { background: #4a1a3f; color: #ee83a1; }

			/* ── aggregate metrics bar ──────────────────── */
			.agg-bar {
				display: flex;
				gap: 1.5rem;
				flex-wrap: wrap;
				padding: 0.5rem 0;
				font-size: 0.85em;
				border-top: 1px solid var(--pico-muted-border-color);
				margin-top: 0.5rem;
			}

			/* ── call log ───────────────────────────────── */
			.log-row    { list-style: none; }
			.log-summary {
				display: flex;
				align-items: center;
				gap: 0.6rem;
				cursor: pointer;
				padding: 0.25rem 0;
				user-select: none;
			}
			.log-payload {
				padding: 0.5rem 0.5rem 0.5rem 1rem;
			}
			.log-payload pre {
				font-size: 0.85em;
				max-height: 200px;
				overflow-y: auto;
				background: var(--pico-card-background-color);
				padding: 0.5rem;
				border-radius: 4px;
				margin: 0.25rem 0 0.75rem;
			}

			/* ── call log dialog ──────────────────────────── */
			.log-dialog {
				width: min(680px, 95vw);
				height: min(80vh, 900px);
				max-width: none;
				max-height: none;
				padding: 0;
				border-radius: 8px;
				border: 1px solid var(--pico-muted-border-color);
				background: var(--pico-background-color);
				overflow: hidden;
			}
			.log-dialog::backdrop {
				background: rgba(0,0,0,0.55);
				backdrop-filter: blur(2px);
			}
			/* sticky trigger button — bottom-right corner */
			.log-open-btn {
				position: fixed;
				bottom: 1.5rem;
				right: 1.5rem;
				z-index: 100;
				padding: 0.5rem 1rem;
				font-size: 0.85em;
				margin: 0;
				box-shadow: 0 2px 12px rgba(0,0,0,0.4);
			}

			/* ── duration tier coloring (consumes --as-lat-* tokens) ── */
			.dur-fast { color: var(--as-lat-fast); }
			.dur-ok   { color: var(--as-lat-ok);   }
			.dur-slow { color: var(--as-lat-slow); }
			.dur-bad  { color: var(--as-lat-bad);  }

			/* ── call-log tabs (Stage 3) ── */
			.log-tabs {
				display: flex;
				gap: 0.25rem;
				margin: 0.4rem 0 0.5rem;
				border-bottom: 1px solid rgba(255,255,255,0.08);
			}
			.log-tab {
				appearance: none;
				background: transparent;
				border: none;
				color: var(--as-muted);
				padding: 0.25rem 0.6rem;
				cursor: pointer;
				font-size: 0.78em;
				border-bottom: 2px solid transparent;
				margin: 0;
				border-radius: 0;
				width: auto;
			}
			.log-tab[aria-selected="true"] {
				color: var(--pico-color);
				border-bottom-color: var(--as-info);
			}
			.log-tab-panel { padding: 0.25rem 0; }
			.log-tab-panel[hidden] { display: none; }
			.log-tab-panel > pre {
				font-size: 0.78em;
				max-height: 300px;
				overflow: auto;
				background: var(--pico-card-background-color);
				padding: 0.5rem;
				border-radius: 4px;
				margin: 0.25rem 0 0.75rem;
			}
			.log-meta { font-size: 0.85em; line-height: 1.7; }
			.log-meta .meta-label { color: var(--as-muted); margin-right: 0.5rem; }

			/* ── JSON tree (Stage 3) ── */
			.json-tree {
				font-family: var(--as-font-mono);
				font-size: 0.78em;
				line-height: 1.55;
			}
			.json-row {
				display: flex;
				align-items: baseline;
				flex-wrap: wrap;
				gap: 0.35rem;
				position: relative;
			}
			.json-row > .json-children {
				flex-basis: 100%;
				padding-left: 1rem;
				border-left: 1px dotted rgba(255,255,255,0.08);
				margin-left: 0.25rem;
			}
			.json-toggle {
				cursor: pointer;
				user-select: none;
				color: var(--as-muted);
				width: 1ch;
				display: inline-block;
			}
			.json-key { color: var(--as-muted); }
			.json-key::after { content: ":"; padding-right: 0.2rem; }
			.json-summary { color: var(--as-muted); cursor: pointer; }
			.json-string { color: var(--as-info); word-break: break-word; }
			.json-number { color: var(--as-warn); }
			.json-bool   { color: var(--as-ok);   }
			.json-null   { color: var(--as-muted); font-style: italic; }
			.json-leaf   { cursor: pointer; }
			.json-leaf:hover {
				background: rgba(255,255,255,0.06);
				border-radius: 2px;
			}
			.json-copy-path,
			.json-copy-full {
				opacity: 0;
				margin-left: 0.25rem;
				cursor: pointer;
				background: rgba(255,255,255,0.08);
				border: none;
				border-radius: 3px;
				color: var(--as-muted);
				font-size: 0.85em;
				padding: 0 0.35rem;
				width: auto;
			}
			.json-row:hover > .json-copy-path,
			.json-row:hover .json-copy-full {
				opacity: 1;
			}

			/* ── envelope reveal (under Response tree) ── */
			.envelope-toggle {
				margin-top: 0.5rem;
				padding-top: 0.4rem;
				border-top: 1px dashed rgba(255,255,255,0.08);
			}
			.envelope-toggle > summary {
				cursor: pointer;
				user-select: none;
				color: var(--as-muted);
				font-size: 0.85em;
				list-style: none;
			}
			.envelope-toggle > summary::before { content: "▸ "; }
			.envelope-toggle[open] > summary::before { content: "▾ "; }

			/* ── call-log Stage 4: sticky header (sparkline + filter bar) ── */
			.log-sticky {
				position: sticky;
				top: 0;
				z-index: 5;
				background: var(--pico-background-color);
				padding: 0.6rem 0 0.5rem;
				margin: 0 -0.25rem;
				border-bottom: 1px solid rgba(255,255,255,0.08);
			}
			.log-sparkline {
				display: block;
				width: 100%;
				height: 40px;
				margin-bottom: 0.45rem;
				overflow: visible;
			}
			.spark-bucket rect.spark-ok  { fill: var(--as-ok);  }
			.spark-bucket rect.spark-err { fill: var(--as-bad); }
			.spark-bucket:hover rect.spark-ok,
			.spark-bucket:hover rect.spark-err { opacity: 0.85; }
			.spark-bucket.active rect.spark-ok,
			.spark-bucket.active rect.spark-err {
				stroke: var(--as-info);
				stroke-width: 1.5;
				paint-order: stroke fill;
			}

			.filter-bar {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				align-items: center;
				font-size: 0.78em;
			}
			.filter-group {
				display: inline-flex;
				gap: 0.15rem;
				align-items: center;
				margin: 0;
				padding: 0;
				border: 0;
			}
			.filter-pill {
				appearance: none;
				background: rgba(255,255,255,0.06);
				border: 1px solid transparent;
				color: var(--pico-color);
				padding: 0.2rem 0.55rem;
				margin: 0;
				cursor: pointer;
				font-size: 0.95em;
				line-height: 1.3;
				border-radius: 4px;
				width: auto;
			}
			.filter-pill:hover { background: rgba(255,255,255,0.12); }
			.filter-pill[aria-pressed="true"] {
				background: rgba(93,173,226,0.18);
				border-color: var(--as-info);
				color: var(--pico-color);
			}
			.filter-pill.dur-fast[aria-pressed="true"] { background: rgba(111,207,151,0.18); border-color: var(--as-lat-fast); color: var(--as-lat-fast); }
			.filter-pill.dur-ok[aria-pressed="true"]   { background: rgba(242,201,76,0.18);  border-color: var(--as-lat-ok);   color: var(--as-lat-ok);   }
			.filter-pill.dur-slow[aria-pressed="true"] { background: rgba(242,153,74,0.18);  border-color: var(--as-lat-slow); color: var(--as-lat-slow); }
			.filter-pill.dur-bad[aria-pressed="true"]  { background: rgba(235,87,87,0.18);   border-color: var(--as-lat-bad);  color: var(--as-lat-bad);  }

			.filter-tools {
				display: inline-flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.3rem;
				flex: 1 1 180px;
				min-width: 140px;
			}
			.tool-chips {
				display: inline-flex;
				flex-wrap: wrap;
				gap: 0.25rem;
			}
			.chip.chip-removable {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				padding-right: 0.25rem;
			}
			.chip.chip-group {
				background: rgba(235,87,87,0.18);
				color: var(--as-bad);
				font-weight: 600;
			}
			.chip-remove {
				appearance: none;
				background: transparent;
				border: none;
				color: var(--as-muted);
				cursor: pointer;
				padding: 0 0.15rem;
				margin: 0;
				font-size: 1.05em;
				line-height: 1;
				width: auto;
				border-radius: 2px;
			}
			.chip-remove:hover { color: var(--as-bad); }

			.filter-tool-input,
			.filter-search {
				flex: 0 1 140px;
				margin: 0;
				padding: 0.2rem 0.5rem;
				font-size: 0.95em;
				background: rgba(255,255,255,0.04);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 4px;
				color: var(--pico-color);
				height: auto;
				min-width: 100px;
			}
			.filter-tool-input:focus,
			.filter-search:focus {
				outline: none;
				border-color: var(--as-info);
			}

			.filter-pause {
				appearance: none;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.12);
				color: var(--pico-color);
				padding: 0.2rem 0.6rem;
				margin: 0 0 0 auto;
				cursor: pointer;
				font-size: 0.95em;
				border-radius: 4px;
				width: auto;
				line-height: 1.3;
			}
			.filter-pause[aria-pressed="true"] {
				background: rgba(242,201,76,0.18);
				border-color: var(--as-warn);
				color: var(--as-warn);
			}

			/* ── virtual list + repeat-error grouping ── */
			.log-virtual { position: relative; padding-top: 0.5rem; }
			.log-spacer  { width: 100%; }
			.log-group > summary { font-weight: 500; }
			.log-group-body {
				padding: 0.25rem 0 0.2rem 0.75rem;
				margin: 0.35rem 0 0 0.4rem;
				border-left: 2px dashed rgba(235,87,87,0.3);
			}
			.log-group-body .log-row { margin-bottom: 0.3rem; }

			/* screen-reader-only live region */
			.visually-hidden {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0,0,0,0);
				white-space: nowrap;
				border: 0;
			}
		</style>
	</head>
}

// trustedNetworkBanner is shown on every page until Stage 9 ships auth.
templ trustedNetworkBanner() {
	<aside class="trusted-network-banner" role="alert">
		⚠ This admin panel has no authentication — bind it to a trusted network only.
	</aside>
}
