package ui

import (
	"fmt"

	"github.com/sebastienmelki/agentsmith/internal/gateway"
)

// BackendDetailPage renders the full detail page for a single backend.
// The static shell (head, top nav, backend identity) never refreshes;
// BackendDetailContent is the live region that polls every 5 s.
// The call log dialog lives outside the polled region so it survives swaps.
templ BackendDetailPage(detail gateway.BackendDetail) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		@sharedHead(detail.Name + " · Agentsmith Admin")
		<body>
			@trustedNetworkBanner()
			<header
				class="container-fluid detail-page-header"
				style="padding: 1rem 2rem; border-bottom: 1px solid var(--pico-muted-border-color); display: flex; align-items: center; gap: 1.5rem;"
			>
				<a href="/" class="secondary" style="white-space: nowrap;">← Dashboard</a>
				<hgroup style="margin: 0;">
					<h2 style="margin: 0;">{ detail.Name }</h2>
					<p class="dim" style="margin: 0;">{ detail.URL }</p>
				</hgroup>
			</header>
			<main class="container-fluid as-main" style="margin-top: 2rem;">
				@BackendDetailContent(detail)
			</main>
			@callLogDialog(detail.Name, detail.Log)
		</body>
	</html>
}

// BackendDetailContent is served both inline (on page load) and as the htmx
// partial at GET /ui/backends/{name}/partial. It replaces itself every 5 s,
// so both the status strip and the tool list stay live without a full reload.
templ BackendDetailContent(detail gateway.BackendDetail) {
	<div hx-get={ "/ui/backends/" + detail.Name + "/partial" } hx-trigger="every 5s" hx-swap="outerHTML">
		@detailStatusStrip(detail)
		@toolList(detail.Tools)
	</div>
}

// detailStatusStrip shows the current connectivity state, key metrics, and
// the per-backend call statistics.
templ detailStatusStrip(d gateway.BackendDetail) {
	<article style="margin-bottom: 2rem;">
		<div class="meta-chips">
			@stateBadge(d.State)
			<span class="dim">
				<strong style="color: inherit;">{ fmt.Sprintf("%d", d.ToolCount) }</strong> tools
			</span>
			<span class="dim">
				<strong style="color: inherit;">{ fmt.Sprintf("%d", max(0, d.ReconnectAttempts-1)) }</strong> reconnects
			</span>
			if d.LastConnectedAt != nil {
				<span class="dim">
					connected&#32;<time
						title={ absoluteTime(d.LastConnectedAt) }
						style="cursor: help; text-decoration: underline dotted;"
					>{ relativeTime(d.LastConnectedAt) }</time>
				</span>
			}
			<span class="refresh-dot" title="auto-refreshes every 5 s" aria-label="auto-refreshes every 5 s" style="margin-left: auto;"></span>
		</div>
		if d.LastError != "" {
			<p style="margin: 0.75rem 0 0; font-size: 0.85em; color: #eb5757;">
				⚠ { d.LastError }
			</p>
		}
		<div class="agg-bar" style="margin-top: 0.75rem;">
			<span><strong>{ fmt.Sprintf("%d", d.Metrics.TotalCalls) }</strong> <span class="dim">calls</span></span>
			<span><strong style={ errorColor(d.Metrics.TotalErrors) }>{ fmt.Sprintf("%d", d.Metrics.TotalErrors) }</strong> <span class="dim">errors</span></span>
			<span><strong>{ fmtPct(d.Metrics.TotalErrors, d.Metrics.TotalCalls) }</strong> <span class="dim">error rate</span></span>
			<span>
				if d.Metrics.TotalCalls == 0 {
					<strong title="No successful calls yet">{ fmtAvgMs(d.Metrics.TotalMs, d.Metrics.TotalCalls) }</strong>
				} else {
					<strong>{ fmtAvgMs(d.Metrics.TotalMs, d.Metrics.TotalCalls) }</strong>
				}
				<span class="dim">avg latency</span>
			</span>
		</div>
	</article>
}

// callLogDialog renders a native <dialog> with the full call log.
// It is placed outside the htmx-polled region so it is never destroyed by
// a background refresh. SSE connects lazily on first open and stays alive
// for the lifetime of the page.
templ callLogDialog(backendName string, entries []gateway.CallEntry) {
	<!-- sticky trigger button -->
	<button
		id="log-open-btn"
		class="log-open-btn"
		onclick="document.getElementById('log-dialog').showModal()"
	>
		&#9656; Call Log
	</button>
	<!-- dialog -->
	<dialog id="log-dialog" class="log-dialog">
		<article style="margin: 0; height: 100%; display: flex; flex-direction: column;">
			<header style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; border-bottom: 1px solid var(--pico-muted-border-color); flex-shrink: 0;">
				<strong>Call Log &mdash; { backendName }</strong>
				<button
					class="secondary outline"
					style="margin: 0; padding: 0.2rem 0.7rem; font-size: 0.85em;"
					onclick="document.getElementById('log-dialog').close()"
				>✕ Close</button>
			</header>
			<div
				id="call-log"
				data-stream-url={ "/ui/backends/" + backendName + "/logs/stream" }
				style="flex: 1; overflow-y: auto; padding: 0.75rem 1.25rem; font-size: 0.8em;"
			>
				if len(entries) == 0 {
					<p class="dim" id="log-empty"><em>No calls recorded yet.</em></p>
				} else {
					for _, e := range entries {
						@callLogRow(e)
					}
				}
			</div>
		</article>
	</dialog>
	<script>
		(function () {
			const dialog = document.getElementById('log-dialog');
			const log    = document.getElementById('call-log');
			let esStarted = false;

			// Connect SSE lazily on first open so we don't hold a connection
			// when the user never opens the panel.
			dialog.addEventListener('close', function () {
				// nothing — keep SSE alive so we don't miss events
			});

			dialog.addEventListener('toggle', function () {
				if (!esStarted) {
					esStarted = true;
					startSSE();
				}
			});

			// Dismiss on backdrop click.
			dialog.addEventListener('click', function (ev) {
				if (ev.target === dialog) dialog.close();
			});

			function startSSE() {
				const es = new EventSource(log.dataset.streamUrl);
				es.addEventListener('log', function (ev) {
					const e = JSON.parse(ev.data);
					const empty = document.getElementById('log-empty');
					if (empty) empty.remove();
					log.insertBefore(buildRow(e), log.firstChild);
					while (log.children.length > 500) log.removeChild(log.lastChild);
				});
			}

			function buildRow(e) {
				const ok   = e.success;
				const wrap = document.createElement('details');
				wrap.className = 'log-row';
				wrap.style.cssText = ok
					? 'border-left:3px solid #1a4731;padding-left:0.5rem;margin-bottom:0.4rem;'
					: 'border-left:3px solid #4a1010;padding-left:0.5rem;margin-bottom:0.4rem;';
				wrap.innerHTML =
					'<summary class="log-summary">' +
						'<span class="state-badge ' + (ok ? 'state-connected' : 'state-error') + '">' + (ok ? 'ok' : 'err') + '</span>' +
						'<code>' + e.toolName + '</code>' +
						'<span class="dim">' + e.durationMs + 'ms</span>' +
						'<span class="dim" style="margin-left:auto">' + new Date(e.calledAt).toLocaleTimeString() + '</span>' +
						(e.error ? '<span style="color:#eb5757">' + e.error + '</span>' : '') +
					'</summary>' +
					'<div class="log-payload">' +
						'<strong>Request</strong><pre>' + (e.request  || '—') + '</pre>' +
						'<strong>Response</strong><pre>' + (e.response || '—') + '</pre>' +
					'</div>';
				return wrap;
			}
		})();
	</script>
}

templ callLogRow(e gateway.CallEntry) {
	<details class="log-row" style={ logRowBorder(e.Success) }>
		<summary class="log-summary">
			if e.Success {
				<span class="state-badge state-connected">ok</span>
			} else {
				<span class="state-badge state-error">err</span>
			}
			<code>{ e.ToolName }</code>
			<span class="dim">{ fmt.Sprintf("%dms", e.DurationMs) }</span>
			<span class="dim" style="margin-left: auto;">{ absoluteTime(&e.CalledAt) }</span>
			if e.Error != "" {
				<span style="color: #eb5757;">{ e.Error }</span>
			}
		</summary>
		<div class="log-payload">
			<strong>Request</strong>
			<pre>{ e.Request }</pre>
			<strong>Response</strong>
			<pre>{ e.Response }</pre>
		</div>
	</details>
}

// toolList renders all tools, or a placeholder while the backend is connecting.
templ toolList(tools []gateway.ToolInfo) {
	if len(tools) == 0 {
		<p class="dim"><em>No tools registered yet — waiting for backend to connect.</em></p>
	} else {
		<h3 style="margin-bottom: 1.25rem;">
			{ fmt.Sprintf("Tools (%d)", len(tools)) }
		</h3>
		for _, t := range tools {
			@toolCard(t)
		}
	}
}

templ toolCard(t gateway.ToolInfo) {
	<article style="margin-bottom: 1.25rem;">
		<header>
			<div class="tool-header">
				<div>
					<code>{ t.Name }</code>
					if t.Title != "" && t.Title != t.Name {
						<span class="dim" style="margin-left: 0.6rem;">{ t.Title }</span>
					}
				</div>
				<div class="badge-row">
					if t.ReadOnly {
						<span class="state-badge badge-readonly">read-only</span>
					}
					if t.Idempotent {
						<span class="state-badge badge-idempotent">idempotent</span>
					}
					if t.Destructive != nil && *t.Destructive {
						<span class="state-badge badge-destructive">destructive</span>
					}
					if t.OpenWorld != nil && *t.OpenWorld {
						<span class="state-badge" style="background: #2a2a50; color: #a29bfe;">open-world</span>
					}
				</div>
			</div>
		</header>
		if t.Description != "" {
			<p style="margin: 0 0 0.75rem; font-size: 0.9em;">{ t.Description }</p>
		}
		if t.InputSchema != "" {
			@schemaSection("Input", t.InputSchema)
		} else if len(t.Params) > 0 {
			@paramsSection(t.Params)
		}
		if t.OutputSchema != "" {
			@schemaSection("Output", t.OutputSchema)
		}
	</article>
}

templ paramsSection(params []gateway.ParamInfo) {
	if len(params) == 0 {
		<p class="dim" style="font-size: 0.8em; margin: 0;">No input parameters.</p>
	} else {
		<figure style="margin: 0; overflow-x: auto;">
			<table class="params">
				<thead>
					<tr>
						<th>Parameter</th>
						<th>Type</th>
						<th>Required</th>
						<th>Description</th>
						<th>Default</th>
					</tr>
				</thead>
				<tbody>
					for _, p := range params {
						<tr>
							<td>
								if p.Required {
									<strong><code>{ p.Name }</code></strong>
								} else {
									<code class="dim">{ p.Name }</code>
								}
							</td>
							<td><span class="dim">{ p.Type }</span></td>
							<td>
								if p.Required {
									<span style="color: #6fcf97; font-size: 0.9em;">✓</span>
								}
							</td>
							<td><span class="dim">{ p.Description }</span></td>
							<td>
								if p.Default != "" {
									<code class="dim" style="font-size: 0.8em;">{ p.Default }</code>
								}
							</td>
						</tr>
					}
				</tbody>
			</table>
		</figure>
	}
}
