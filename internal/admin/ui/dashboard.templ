package ui

import (
	"fmt"

	"github.com/sebastienmelki/agentsmith/internal/gateway"
)

// Dashboard renders the full admin dashboard page.
templ Dashboard(backends []gateway.BackendDetail, agg gateway.Metrics, unprotected bool) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		@sharedHead("Agentsmith · Admin")
		<body>
			if unprotected {
				@unprotectedModeBanner()
			} else {
				@trustedNetworkBanner()
			}
			<header
				class="container-fluid"
				style="padding: 1.25rem 2rem; border-bottom: 1px solid var(--pico-muted-border-color); display: flex; align-items: center; justify-content: space-between; gap: 1rem;"
			>
				<hgroup style="margin: 0;">
					<h2 style="margin: 0;">⚙️ Agentsmith</h2>
					<p style="margin: 0;">Admin · MCP Gateway</p>
				</hgroup>
				<nav style="margin: 0;">
					<a href="/users" class="secondary">Users</a>
				</nav>
			</header>
			<main class="container-fluid as-main" style="margin-top: 2rem;">
				@BackendsPanel(backends, agg)
			</main>
		</body>
	</html>
}

// BackendsPanel renders the backends status table.
// Also served standalone at GET /ui/backends for htmx polling.
templ BackendsPanel(backends []gateway.BackendDetail, agg gateway.Metrics) {
	<article hx-get="/ui/backends" hx-trigger="every 5s" hx-swap="outerHTML">
		<header class="panel-header">
			<strong>Backends</strong>
			<small class="dim" style="display: inline-flex; align-items: center; gap: 0.5rem;">
				{ fmt.Sprintf("%d / %d connected", connectedCount(backends), len(backends)) }
				<span class="refresh-dot" title="auto-refreshes every 5 s" aria-label="auto-refreshes every 5 s"></span>
			</small>
		</header>
		@aggregateMetricsBar(agg)
		if len(backends) == 0 {
			<p><em>No backends configured.</em></p>
		} else {
			<figure class="table-scroll" style="margin: 0;">
				<table>
					<thead>
						<tr>
							<th>Backend</th>
							<th>State</th>
							<th class="num">Tools</th>
							<th class="num">Calls</th>
							<th class="num">Errors</th>
							<th class="num">Avg ms</th>
							<th class="num">Reconnects</th>
							<th class="col-last-connected">Last Connected</th>
							<th>Last Error</th>
						</tr>
					</thead>
					<tbody>
						for _, b := range backends {
							@backendRow(b)
						}
					</tbody>
				</table>
			</figure>
		}
	</article>
}

// aggregateMetricsBar shows a one-line summary of gateway-wide call stats.
templ aggregateMetricsBar(m gateway.Metrics) {
	if m.TotalCalls > 0 {
		<div class="agg-bar">
			<span><strong>{ fmt.Sprintf("%d", m.TotalCalls) }</strong> <span class="dim">calls</span></span>
			<span><strong style={ errorColor(m.TotalErrors) }>{ fmt.Sprintf("%d", m.TotalErrors) }</strong> <span class="dim">errors</span></span>
			<span><strong>{ fmtPct(m.TotalErrors, m.TotalCalls) }</strong> <span class="dim">error rate</span></span>
			<span><strong>{ fmtAvgMs(m.TotalMs, m.TotalCalls) }</strong> <span class="dim">avg latency</span></span>
		</div>
	}
}

templ backendRow(b gateway.BackendDetail) {
	<tr>
		<td>
			<a href={ templ.SafeURL("/ui/backends/" + b.Name) }>
				<strong>{ b.Name }</strong>
			</a>
			<br/>
			<span class="dim backend-url">{ b.URL }</span>
		</td>
		<td>@stateBadge(b.State)</td>
		<td class="num">{ fmt.Sprintf("%d", b.ToolCount) }</td>
		<td class="num">{ fmt.Sprintf("%d", b.Metrics.TotalCalls) }</td>
		<td class="num" style={ errorColor(b.Metrics.TotalErrors) }>{ fmt.Sprintf("%d", b.Metrics.TotalErrors) }</td>
		<td class="num">
			if b.Metrics.TotalCalls == 0 {
				<span title="No successful calls yet">{ fmtAvgMs(b.Metrics.TotalMs, b.Metrics.TotalCalls) }</span>
			} else {
				{ fmtAvgMs(b.Metrics.TotalMs, b.Metrics.TotalCalls) }
			}
		</td>
		<td class="num">{ fmt.Sprintf("%d", max(0, b.ReconnectAttempts-1)) }</td>
		<td class="col-last-connected">
			if b.LastConnectedAt != nil {
				<time
					class="dim"
					title={ absoluteTime(b.LastConnectedAt) }
					style="cursor: help; text-decoration: underline dotted;"
				>{ relativeTime(b.LastConnectedAt) }</time>
			} else {
				<span class="dim">—</span>
			}
		</td>
		<td>
			if b.LastError != "" {
				<small style="color: #eb5757;">{ b.LastError }</small>
			} else {
				<span class="dim">—</span>
			}
		</td>
	</tr>
}

templ stateBadge(state gateway.BackendState) {
	switch state {
		case gateway.StateConnected:
			<span class="state-badge state-connected">connected</span>
		case gateway.StateConnecting:
			<span class="state-badge state-connecting">connecting</span>
		default:
			<span class="state-badge state-error">{ string(state) }</span>
	}
}
