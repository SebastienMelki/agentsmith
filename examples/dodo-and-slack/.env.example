# Backend credentials for the dodo-and-slack example.
# Copy this file to agentsmith.env at the repo root (gitignored) and fill in real values.
# Variable names here must match the ${VAR} references in config.yaml.

# Dodo Payments — https://dodopayments.com
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_key_here

# Slack bot token — https://api.slack.com/apps
SLACK_TOKEN=xoxb-your-slack-bot-token-here
